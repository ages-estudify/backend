DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backend?schema=public"

# Auth / JWT
JWT_SECRET='17c3c317521b29e39862110e12469a46bffa076a2eada28ff2020e781400bd3b4eaaaf168d1a9c7cc187a722e3a0805b2d637e8eccd2929cb1382701101277fa'
# Token TTL in seconds (optional; default 7 days)
JWT_EXPIRES_IN_SEC=
# bcrypt cost factor, 4–15 (optional; default 10)
BCRYPT_ROUNDS=

# Refresh tokens (opaque; only hashes stored in DB)
# TTL in days for new refresh sessions (optional; default 30, max 365)
REFRESH_TOKEN_TTL_DAYS=
# Optional server-side pepper concatenated before hashing (recommended in production)
REFRESH_TOKEN_PEPPER=

# S3 (local: fill all; ECS: region/bucket/TTL via SSM, keys via Secrets Manager — see .aws/task-definition.json)
AWS_REGION=us-east-1
AWS_S3_BUCKET=bucket-local
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
# Presigned URL TTL in seconds (default 3600)
S3_SIGNED_URL_EXPIRES_IN=3600