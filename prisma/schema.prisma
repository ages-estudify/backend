generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADM
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Language {
  ENGLISH
  SPANISH
}

enum Origin {
  ORIGINAL
  EXTERNAL
}

enum PlanType {
  TRIMESTRAL
  ANUAL
}

enum ExamStatus{
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  full_name      String
  email          String         @unique
  password       String
  phone_number   String         @unique
  role           Role
  plan_end_date  DateTime?
  streak         Int?
  coins          Int?
  createdAt      DateTime       @default(now())
  enable         Boolean        @default(true)
  desired_course String?
  desired_university String?
  preferred_language Language?
  last_active    DateTime?
  birth_date     DateTime?      @db.Date
  Study_day      StudyDay[]
  answers        Answer[]
  attempts       Attempt[]
  StudyLog       StudyLog[]
  refresh_tokens RefreshToken[]
  subscriptions  Subscription[]
  onboarding_completed Boolean @default(false)
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique
  user_id   String   @db.Uuid
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([user_id])
}

model StudyDay {
  id      String  @id @default(uuid()) @db.Uuid
  day     WeekDay
  hour    Int
  user_id String  @db.Uuid
  user    User    @relation(fields: [user_id], references: [id])
}

model StudyLog {
  id   String   @id @default(uuid()) @db.Uuid
  date DateTime
  done Boolean  @default(false)

  user_id String @db.Uuid
  user    User   @relation(fields: [user_id], references: [id])

  path_id String @db.Uuid
  path    Path   @relation(fields: [path_id], references: [id])

  @@unique([user_id, path_id, date])
}

model Subject {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  icon_url String
  paths    Path[]
}

model Path {
  id                String @id @default(uuid()) @db.Uuid
  name              String
  text              String
  icon_url          String
  schedule_position Int    @unique
  trail_position    Int

  subject_id String     @db.Uuid
  subject    Subject    @relation(fields: [subject_id], references: [id])
  questions  Question[]
  studyLog   StudyLog[]

  @@unique([subject_id, trail_position])
}

model Exam {
  id        String  @id @default(uuid()) @db.Uuid
  name      String
  origin    String
  image_url String?
  status    ExamStatus @default(DRAFT)

  exam_days ExamDay[]
  attempts Attempt[]
}

model ExamDay {
  id  String @id @default(uuid()) @db.Uuid
  day Int

  exam_id String @db.Uuid
  Exam    Exam   @relation(fields: [exam_id], references: [id])

  attempts_day AttemptDay[]
  questions    Question[]
}

model Attempt {
  id                 String    @id @default(uuid()) @db.Uuid
  time_spent_minutes Int
  score              Int?
  language           Language
  init_time          DateTime
  end_time           DateTime?

  exam_id      String        @db.Uuid
  exam         Exam          @relation(fields: [exam_id], references: [id])
  user_id      String        @db.Uuid
  user         User          @relation(fields: [user_id], references: [id])
  attempt_days AttemptDay[]
}

model AttemptDay {
  id                 String    @id @default(uuid()) @db.Uuid
  time_spent_minutes Int
  current_question   Int
  init_time          DateTime
  end_time           DateTime?

  attempt_id  String   @db.Uuid
  attempt     Attempt  @relation(fields: [attempt_id], references: [id])
  exam_day_id String   @db.Uuid
  exam_day    ExamDay @relation(fields: [exam_day_id], references: [id])
  answers     Answer[]

  @@unique([attempt_id, exam_day_id])
}

model Question {
  id        String    @id @default(uuid()) @db.Uuid
  text      String
  origin    Origin
  year      Int
  feedback  String
  number    Int?
  language  Language?
  image_url String?

  path_id      String        @db.Uuid
  path         Path          @relation(fields: [path_id], references: [id])
  exam_day_id  String?       @db.Uuid
  exam_day     ExamDay?     @relation(fields: [exam_day_id], references: [id])
  alternatives Alternative[]
  answers      Answer[]
}

model Alternative {
  id         String  @id @default(uuid()) @db.Uuid
  text       String
  letter     String  @db.Char(1)
  is_correct Boolean

  question_id String   @db.Uuid
  question    Question @relation(fields: [question_id], references: [id])
  answers     Answer[]
}

model Answer {
  id          String   @id @default(uuid()) @db.Uuid
  answer_date DateTime

  user_id        String       @db.Uuid
  user           User         @relation(fields: [user_id], references: [id])
  question_id    String       @db.Uuid
  question       Question     @relation(fields: [question_id], references: [id])
  alternative_id String?      @db.Uuid
  alternative    Alternative? @relation(fields: [alternative_id], references: [id])
  attempt_day_id String?      @db.Uuid
  attempt_day    AttemptDay? @relation(fields: [attempt_day_id], references: [id])
}

model Subscription {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan_type  PlanType
  start_date DateTime
  end_date   DateTime
  created_at DateTime @default(now())

  @@index([user_id])
}
