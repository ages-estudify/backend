generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADM
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Language{
  ENGLISH
  SPANISH
}

enum Origin {
  ORIGINAL
  EXTERNAL
}

model User {

  id              String    @id      @default(uuid()) @db.Uuid
  full_name       String
  email           String    @unique
  password        String
  phone_number    String
  role            Role
  plan_end_date   DateTime?
  streak          Int?
  coins           Int?
  createdAt       DateTime           @default(now())
  enable          Boolean            @default(true)
  schedule_init   DateTime?
  desired_course  String?
  desired_exam    String?
  Study_day       StudyDay[]
  answers         Answer[]
  attempts        Attempt[]

}

model StudyDay{

  id              String    @id      @default(uuid()) @db.Uuid
  day             WeekDay
  hour            Int
  user_id         String                              @db.Uuid
  user            User   @relation(fields: [user_id], references: [id])

}

model Subject{
  
  id      String    @id      @default(uuid()) @db.Uuid
  name    String
  topics  Topic[]

}

model Topic{
  
  id        String    @id      @default(uuid()) @db.Uuid
  name      String
  position  Int
  subject_id  String @db.Uuid
  subject     Subject          @relation(fields: [subject_id], references: [id])
  questions               Question[]

}

model Exam{

  id                      String    @id      @default(uuid()) @db.Uuid
  name                    String
  estimated_time_minutes  Int
  origin                  String
  attempts                Attempt[]
  questions               Question[]

}

model Attempt{

  id                      String    @id      @default(uuid()) @db.Uuid
  time_spent_minutes      Int
  score                   Int?
  current_question        Int
  language                Language
  init_time               DateTime
  end_time                DateTime?
  exam_id                 String   @db.Uuid
  exam                    Exam     @relation(fields: [exam_id], references: [id])
  user_id                 String   @db.Uuid
  user                    User     @relation(fields: [user_id], references: [id])
  answers                 Answer[]
}

model Question{

  id                      String    @id      @default(uuid()) @db.Uuid
  text                    String
  origin                  Origin
  year                    Int
  feedback                String
  day                     Int
  number                  Int?
  language                Language?
  image_url               String?
  topic_id                String   @db.Uuid
  topic                   Topic    @relation(fields: [topic_id], references: [id])
  exam_id                 String?   @db.Uuid
  exam                    Exam?    @relation(fields: [exam_id], references: [id])
  alternatives            Alternative[]
  answers                 Answer[]
}

model Alternative{

  id                      String    @id      @default(uuid()) @db.Uuid
  text                    String
  letter                  String @db.Char(1)
  is_correct              Boolean
  question_id             String  @db.Uuid
  question                Question  @relation(fields: [question_id], references: [id])
  answers                 Answer[]

}

model Answer{

  id                      String    @id      @default(uuid()) @db.Uuid
  user_id                 String   @db.Uuid
  user                    User     @relation(fields: [user_id], references: [id])
  question_id             String  @db.Uuid
  question                Question  @relation(fields: [question_id], references: [id])
  alternative_id          String  @db.Uuid
  alternative             Alternative @relation(fields: [alternative_id], references: [id])
  attempt_id              String?  @db.Uuid
  attempt                 Attempt?     @relation(fields: [attempt_id], references: [id])

}