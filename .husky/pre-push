#!/bin/bash

local_branch_name="$(git rev-parse --abbrev-ref HEAD)"

# Regex: tipo/id-clickup/nome (classes sem \- \. por compatibilidade com Bash 3.2 no macOS)
valid_branch_regex="^(develop|main)$|^(feature|fix|hotfix|chore|refactor|arch|docs|test)/[-a-zA-Z0-9.]+/[a-z0-9-]+$"

if [[ ! $local_branch_name =~ $valid_branch_regex ]]
then
    echo "❌ Erro: Nome de branch inválido!"
    echo "Padrão: tipo/id_clickup/nome-da-branch"
    exit 1
fi